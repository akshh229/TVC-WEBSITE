NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY= # Legacy name also supported by the app.
# Preferred for new projects. Legacy service-role keys remain supported.
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_DEMO_DATA=true

# Optional admin alerts through Resend. The sender must use a verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=The Voyage Club <notifications@example.com>
# Comma-separated; up to 50 recipients.
ADMIN_NOTIFICATION_EMAILS=
